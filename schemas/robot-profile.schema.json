{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "V7RC Robot Profile",
  "type": "object",
  "required": [
    "profile_name",
    "profile_version",
    "robot",
    "protocol",
    "safety"
  ],
  "properties": {
    "profile_name": {
      "type": "string"
    },
    "profile_version": {
      "type": "string"
    },
    "robot": {
      "type": "object"
    },
    "protocol": {
      "type": "object"
    },
    "motion": {
      "type": "object"
    },
    "led": {
      "type": "object"
    },
    "custom_commands": {
      "type": "object"
    },
    "intents": {
      "type": "object"
    },
    "safety": {
      "type": "object"
    }
  }
}